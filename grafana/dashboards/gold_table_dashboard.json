      "panel-11": {
        "kind": "Panel",
        "spec": {
          "id": 11,
          "title": "Evolución Semestral: Tasa Estudiantes por Docente (SUE)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-postgresql-datasource",
                      "version": "v0",
                      "spec": {
                        "dataset": "snies",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \r\n  -- Creamos una fecha real usando el año y el semestre\r\n  -- Semestre 1 -> 01 de Junio, Semestre 2 -> 01 de Diciembre\r\n  TO_DATE(\r\n    data_year::text || '-' || (CASE WHEN semester = 1 THEN '01' ELSE '07' END) || '-01', \r\n    'YYYY-MM-DD'\r\n  ) AS time,\r\n  -- Calculamos el ratio\r\n  (SUM(total_enrolled)::float / NULLIF(SUM(total_teachers), 0)) AS \"Tasa por Semestre\"\r\nFROM gold.student_teacher_ratio\r\nWHERE is_sue_member = true\r\nGROUP BY data_year, semester\r\nORDER BY time ASC;",
                        "sql": {
                          "columns": [
                            {
                              "name": "SUM",
                              "parameters": [
                                {
                                  "name": "total_enrolled",
                                  "type": "functionParameter"
                                }
                              ],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
